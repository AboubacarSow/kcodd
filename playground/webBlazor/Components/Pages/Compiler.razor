@page "/compiler"
@using System.Text.Json
@using System.Diagnostics

@inject TranspilerService Transpiler
@inject IJSRuntime JS

@rendermode InteractiveServer

<PageTitle>Compiler — KCodd</PageTitle>

<div class="compiler-page">

    <nav class="nav">
        <a class="nav-brand" href="/">
            <div class="nav-brand-mark" style=@(_isDark ? "background-color: #333; color: #fff;" : "background-color: #f0f0f0; color: #333;")>
                <img src=@(_isDark ? "/kcodd_logo_dark.svg" : "/kcodd_logo_light.svg") alt="KCodd logo" class="nav-brand-logo-img" />
            </div>
        </a>
        <div class="nav-pill">Engine ready v1.0.0</div>
        <div style="display:flex;align-items:center;gap:0.75rem;">
            <button class="btn-theme" @onclick="ToggleTheme" title="Toggle theme">
                @if (_isDark)
                {
                    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                        <circle cx="12" cy="12" r="4"/><line x1="12" y1="2" x2="12" y2="6"/><line x1="12" y1="18" x2="12" y2="22"/>
                        <line x1="4.93" y1="4.93" x2="7.76" y2="7.76"/><line x1="16.24" y1="16.24" x2="19.07" y2="19.07"/>
                        <line x1="2" y1="12" x2="6" y2="12"/><line x1="18" y1="12" x2="22" y2="12"/>
                        <line x1="4.93" y1="19.07" x2="7.76" y2="16.24"/><line x1="16.24" y1="7.76" x2="19.07" y2="4.93"/>
                    </svg>
                }
                else
                {
                    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                        <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/>
                    </svg>
                }
            </button>
            <a class="nav-back" href="/">← Home</a>
        </div>
    </nav>

    <div class="compiler-layout">

        <!-- Sidebar -->
        <aside class="sidebar">

            <!-- Relational operators -->
            <div>
                <span class="sidebar-label">Operators</span>
                <div class="op-grid">
                    @foreach (var op in _ops)
                    {
                        <button class="op-key"
                                title="@op.Name"
                                @onclick="() => Insert(op.Insert)">
                            <span class="k-sym">@op.Sym</span>
                            <span class="k-name">@op.Name</span>
                        </button>
                    }
                </div>
            </div>

            <!-- Comparison operators -->
            <div>
                <span class="sidebar-label">Comparison</span>
                <div class="cmp-row">
                    @foreach (var c in _cmp)
                    {
                        <button class="cmp-key" @onclick="() => Insert(c)">@c</button>
                    }
                </div>
            </div>

            <!-- Snippets -->
            <div>
                <span class="sidebar-label">Snippets</span>
                @foreach (var s in _snippets)
                {
                    <div class="snippet" @onclick="() => UseSnippet(s.Code)">
                        <div class="snippet-code">@s.Code</div>
                        <div class="snippet-desc">@s.Desc</div>
                    </div>
                }
            </div>

            <!-- History -->
            @if (_history.Count > 0)
            {
                <div>
                    <span class="sidebar-label">History</span>
                    @foreach (var h in ((IEnumerable<string>)_history).Reverse().Take(8))
                    {
                        <div class="history-item" title="@h" @onclick="() => UseSnippet(h)">
                            @h
                        </div>
                    }
                </div>
            }
        </aside>

        <!-- Main -->
        <main class="main-panel">

            <div class="input-area">
                <label for="raInput">Expression</label>
                <textarea id="raInput"
                          class="ra-input"
                          placeholder="σ [age > 18] (Student)"
                          @bind="_input"
                          @bind:event="oninput"
                          @onkeydown="HandleKey"
                          @key="_inputKey"
                          rows="3"></textarea>
                <div class="input-footer">
                    <button class="btn-primary"
                            @onclick="Transpile"
                            disabled="@(_loading || string.IsNullOrWhiteSpace(_input))"
                            style=@(_isDark ? "background-color: #555; color: #fff;" : "background-color: #ddd; color: #333;")>
                        @if (_loading)
                        {
                            <span class="spinner"></span>
                            <span>Running</span>
                        }
                        else
                        {
                            <span>Run</span>
                        }
                    </button>
                    <button class="btn-ghost" @onclick="async () => await Clear()">Clear</button>
                    <span class="input-hint">Ctrl + Enter to run</span>
                </div>
            </div>

            <div class="output-area" id="outputPane">
                @if (_results.Count == 0)
                {
                    <div class="output-empty">
                        <p>Results will appear here.</p>
                    </div>
                }
                else
                {
                    @foreach (var r in ((IEnumerable<Result>)_results).Reverse())
                    {
                        <div class="result">
                            <div class="result-header">
                                <span class="result-status @(r.IsError ? "err" : "ok")">
                                    @(r.IsError ? "Error" : "SQL generated")
                                </span>
                                <div class="result-meta-group">
                                    @if (r.Elapsed is not null)
                                    {
                                        <span class="result-elapsed">@r.Elapsed</span>
                                    }
                                    <span class="result-meta">@r.At.ToString("HH:mm:ss")</span>
                                </div>
                            </div>

                            <div class="result-input-row">@r.Ra</div>

                            <div class="result-body">
                                @if (r.IsError)
                                {
                                    <div class="result-error">@r.Sql</div>
                                }
                                else
                                {
                                    <div class="result-sql">@r.Sql</div>
                                }
                            </div>

                            @if (!r.IsError)
                            {
                                <div class="result-footer">
                                    <button class="btn-copy @(r.Copied ? "copied" : "")"
                                            @onclick="() => Copy(r)">
                                        @(r.Copied ? "Copied" : "Copy SQL")
                                    </button>
                                </div>
                            }
                        </div>
                    }
                }
            </div>
        </main>
    </div>
</div>

@code {
    string  _input    = "";
    int     _inputKey = 0;
    bool    _isDark;
    bool    _loading;
    List<Result> _results = [];
    List<string> _history = [];

    // ── Lifecycle ──────────────────────────────────────────────────────────────
    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        var saved = await JS.InvokeAsync<string>("getTheme");
        _isDark = saved == "dark";

        if (firstRender)
        {
            await LoadResults();
            StateHasChanged();
        }
    }

    // ── Persistence ────────────────────────────────────────────────────────────
    async Task LoadResults()
    {
        var json = await JS.InvokeAsync<string>("getResults", "query_results");
        if (!string.IsNullOrEmpty(json))
        {
            _results = JsonSerializer.Deserialize<List<Result>>(json)!;
            _history = _results.Select(r => r.Ra).Distinct().ToList();
            if (_history.Count > 30) _history = _history.TakeLast(30).ToList();
        }
    }

    async Task AddNewResult()
        => await JS.InvokeVoidAsync("storeResult", "query_results", JsonSerializer.Serialize(_results));

    async Task ClearResults()
        => await JS.InvokeVoidAsync("clearResults", "query_results");

    // ── Theme ──────────────────────────────────────────────────────────────────
    async Task ToggleTheme()
    {
        _isDark = !_isDark;
        await JS.InvokeVoidAsync("setTheme", _isDark ? "dark" : "light");
    }

    // ── Operator palette ───────────────────────────────────────────────────────
    readonly Op[] _ops = Tools.Ops;

    readonly string[] _cmp = ["=", "≠", "<", ">", "≤", "≥"];

    readonly Snippet[] _snippets = Tools.Snippets;


    // ── Actions ────────────────────────────────────────────────────────────────
    void Insert(string text)
    {
        _input = (_input ?? "") + text;
        _inputKey++;
    }

    void UseSnippet(string code)
    {
        _input = code;
        _inputKey++;
    }

    async Task Clear()
    {
        _input    = "";
        _inputKey++;
        _results.Clear();
        await ClearResults();
    }

    async Task HandleKey(KeyboardEventArgs e)
    {
        if (e.Key == "Enter" && e.CtrlKey) await Transpile();
    }

    async Task Transpile()
    {
        if (string.IsNullOrWhiteSpace(_input)) return;

        _loading = true;
        StateHasChanged();
        await Task.Delay(1);

        var ra = _input!.Trim();
        try
        {
            var sw = Stopwatch.StartNew();
            string sql = Transpiler.Transpile(ra);
            sw.Stop();
            _results.Add(new Result(ra, sql, false, DateTime.Now,
                sw.ElapsedMilliseconds + " ms"));
        }
        catch (Exception ex)
        {
            _results.Add(new Result(ra, ex.Message, true, DateTime.Now, null));
        }
        finally
        {
            await AddNewResult();
            _loading = false;
            if (!_history.Contains(ra)) _history.Add(ra);
            if (_history.Count > 30) _history.RemoveAt(0);
        }

        await JS.InvokeVoidAsync("scrollToBottom", "outputPane");
    }

    async Task Copy(Result r)
    {
        await JS.InvokeVoidAsync("navigator.clipboard.writeText", r.Sql);
        r.Copied = true;
        StateHasChanged();
        await Task.Delay(1800);
        r.Copied = false;
        StateHasChanged();
    }

   
}
